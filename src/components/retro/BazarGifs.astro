<div class="bazar-badges">
  <div class="badge">
    <img src="assets/construction.gif" alt="IE 6.0" />
    <span>Best with IE 6.0</span>
  </div>
  <div class="badge">
    <img src="assets/new.gif" alt="Notepad" />
    <span>Made with Notepad</span>
  </div>
  <div class="badge">
    <div class="pixel-text">TOP 100 FOLK</div>
  </div>
</div>

<style>
  .bazar-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    padding: 10px;
    background: #000;
    border: 2px inset #fff;
  }
  .badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #c0c0c0;
    border: 2px outset #fff;
    padding: 4px;
    font-size: 9px;
    font-family: monospace;
    width: 80px;
  }
  .badge img {
    height: 20px;
    margin-bottom: 2px;
  }
  .pixel-text {
    background: blue;
    color: white;
    font-weight: bold;
    padding: 2px;
    border: 1px solid #fff;
  }
</style>
