---
interface Props {
  text: string;
  speed?: string;
  backgroundColor?: string;
  textColor?: string;
}

const { 
  text, 
  speed = "20s", 
  backgroundColor = "#000", 
  textColor = "#0f0" 
} = Astro.props;
---

<div class="marquee-container" style={`background: ${backgroundColor}; color: ${textColor};`}>
  <div class="marquee-content" style={`animation-duration: ${speed};`}>
    {text} &nbsp;&nbsp;&nbsp; {text} &nbsp;&nbsp;&nbsp; {text} &nbsp;&nbsp;&nbsp; {text}
  </div>
</div>

<style>
  .marquee-container {
    width: 100%;
    overflow: hidden;
    white-space: nowrap;
    padding: 5px 0;
    border: 2px inset #fff;
  }

  .marquee-content {
    display: inline-block;
    padding-left: 100%;
    animation: marquee linear infinite;
    font-family: 'Courier New', Courier, monospace;
    font-weight: bold;
    font-size: 14px;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }
</style>
