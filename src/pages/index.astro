---
import '../styles/bazar-wave.css';
import '../styles/workbench.css';
import '../components/retro/WordArt.css';
import Marquee from '../components/retro/Marquee.astro';
import StagePlayer from '../components/retro/StagePlayer.tsx';
import HitCounter from '../components/retro/HitCounter.tsx';
import VaporwaveTroope from '../components/retro/VaporwaveTroope.tsx';
import BootSequence from '../components/retro/BootSequence.astro';
import RetroVideo from '../components/retro/RetroVideo.astro';
import Gallery from '../components/retro/Gallery.tsx';
import KujawiakWinMenuItem from '../components/retro/KujawiakWinMenuItem.astro';
import Guestbook from '../components/retro/Guestbook.tsx';
import WinAmp from '../components/retro/WinAmp/WinAmp.tsx';
import KujawyMap from '../components/retro/KujawyMap.tsx';
import DraggableWindow from '../components/retro/DraggableWindow.tsx';
import MerchWizard from '../components/retro/MerchWizard.tsx';
import AccordionGame from '../components/retro/AccordionGame.tsx';
import LivingBazar from '../components/retro/LivingBazar.tsx';
import Taskbar from '../components/retro/Taskbar.tsx';
import MirekHelper from '../components/retro/MirekHelper.tsx';
import PolonezBrowser from '../components/retro/PolonezBrowser.tsx';
import BazarSettings from '../components/retro/BazarSettings.tsx';
import SpiritusShield from '../components/retro/SpiritusShield.tsx';
import ChaosHeader from '../components/retro/ChaosHeader.tsx';
import DesktopSurface from '../components/retro/DesktopSurface.tsx';
import SystemLogs from '../components/retro/SystemLogs.tsx';
import AssetVault from '../components/retro/AssetVault.tsx';
import SystemWarnings from '../components/retro/SystemWarnings.tsx';
import BazarTerminal from '../components/retro/BazarTerminal.tsx';
import OnboardingWizard from '../components/retro/OnboardingWizard.tsx';
import NewsTicker from '../components/retro/NewsTicker.tsx';
import StickerBomb from '../components/retro/StickerBomb.tsx';
import ContextMenu from '../components/retro/ContextMenu.tsx';
import BazarScreensaver from '../components/retro/BazarScreensaver.tsx';
import MerchListing from '../components/retro/MerchListing.tsx';
import MirekChat from '../components/retro/MirekChat.tsx';
import RaptemLore from '../components/retro/RaptemLore.tsx';
import LoreGlitches from '../components/retro/LoreGlitches.tsx';
import RitualSync from '../components/retro/RitualSync.tsx';
import BazarMediaPlayer from '../components/retro/BazarMediaPlayer.tsx';
import BazarSoundRecorder from '../components/retro/BazarSoundRecorder.tsx';
import MultimediaSettings from '../components/retro/MultimediaSettings.tsx';
import BazarDiskDefragmenter from '../components/retro/BazarDiskDefragmenter.tsx';
import StageGlitches from '../components/retro/StageGlitches.tsx';
import FolkPatternGenerator from '../components/retro/FolkPatternGenerator.tsx';
import DesktopWidgets from '../components/retro/DesktopWidgets.tsx';
import QuestLog from '../components/retro/QuestLog.tsx';
import RitualDatabase from '../components/retro/RitualDatabase.tsx';
import TheaterArchive from '../components/retro/TheaterArchive.tsx';
import FolkloreScanner from '../components/retro/FolkloreScanner.tsx';
import PlayerProfile from '../components/retro/PlayerProfile.tsx';
import { ViewTransitions } from 'astro:transitions';
---

<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <base href={import.meta.env.BASE_URL} />
    <title>RAPTEM - Oficjalna Strona Kujawskiego Teatru</title>
    <ViewTransitions />
  </head>
  <body>
    <div id="drunk-overlay" class="pointer-events-none fixed inset-0 z-[400000] hidden"></div>
    <svg style="position: absolute; width: 0; height: 0;">
      <filter id="wavy-filter">
        <feTurbulence type="fractalNoise" baseFrequency="0.01" numOctaves="3" result="noise" />
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="20" />
      </filter>
    </svg>
    <!-- GLOBAL BAZAR UI LAYER -->
    <div id="global-ui">
      <ChaosHeader client:load />
      <NewsTicker client:load />
      <ContextMenu client:load />
      <BazarScreensaver client:load />
      <StickerBomb client:load count={20} />
      <SystemWarnings client:load />
      <LoreGlitches client:load />
      <StageGlitches client:load />
      <FolkPatternGenerator client:load opacity={0.12} count={15} />
      <LivingBazar client:load />
    </div>
    
    <!-- WINDOW MANAGEMENT LAYER (Always Active) -->
    <div id="window-layer" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 9000;">
      <div style="pointer-events: auto;">
        <DraggableWindow client:load id="readme" title="README.TXT" initialX={100} initialY={100} initialWidth={600}>
          <div style="padding: 20px; background: #fff; color: #000; font-family: monospace;">
            <p>WITAJ W SYSTEMIE OPERACYJNYM RAPTEM.</p>
            <p style="margin-top: 10px;">System działa w tle klasycznej strony. Możesz otwierać okna z Taskbaru poniżej!</p>
          </div>
        </DraggableWindow>

        <DraggableWindow client:load id="quest_log" title="DZIENNIK_MISJI.LOG" initialX={700} initialY={100}>
          <QuestLog client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="terminal" title="BAZAR_TERMINAL.EXE" initialX={50} initialY={50} initialWidth={600}>
          <BazarTerminal client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="lore" title="MANIFEST_BAZAROWY.RTF" initialX={150} initialY={150} initialWidth={500}>
          <RaptemLore client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="gallery_os" title="GALERIA_ZDJEC.EXE" initialX={200} initialY={200} initialWidth={700}>
          <Gallery client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="polonez" title="MOJ_POLONEZ.SYS" initialX={300} initialY={250} initialWidth={500}>
          <PolonezBrowser client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="network" title="OTOCZENIE_BAZAROWE.ZIP" initialX={400} initialY={300} initialWidth={450}>
          <AssetVault client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="winamp" title="WINAMP_BAZAR_SKIN" initialX={600} initialY={400} initialWidth={275}>
          <WinAmp client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="accordion" title="BAZAR_MASTER_9000" initialX={250} initialY={100} initialWidth={800}>
          <AccordionGame client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="logs" title="LOGI_SYSTEMOWE.LOG" initialX={500} initialY={450} initialWidth={400}>
          <SystemLogs client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="settings" title="USTAWIENIA_SPEKTAKLU.INI" initialX={450} initialY={200} initialWidth={400}>
          <BazarSettings client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="rituals" title="BAZA_RYTUALOW.DB" initialX={150} initialY={300} initialWidth={500} initialHeight={400}>
          <RitualDatabase client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="archive" title="ARCHIWUM_TEATRALNE.DOC" initialX={300} initialY={100} initialWidth={550} initialHeight={450}>
          <TheaterArchive client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="map" title="MAPA_REGIONU.EXE" initialX={200} initialY={150} initialWidth={600} initialHeight={500}>
          <KujawyMap client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="scanner" title="SKANER_FOLKLORU.EXE" initialX={400} initialY={400} initialWidth={350} initialHeight={300}>
          <FolkloreScanner client:load />
        </DraggableWindo        <DraggableWindow client:load id="profile" title="PROFIL_SOŁTYSA.EXE" initialX={350} initialY={150} initialWidth={400}>
          <PlayerProfile client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="guestbook" title="KSIEGA_GOSCI.DB" initialX={450} initialY={300} initialWidth={450}>
          <Guestbook client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="defrag" title="BAZAR_DEFRAG.EXE" initialX={500} initialY={100} initialWidth={400}>
          <BazarDiskDefragmenter client:load />
        </DraggableWindow>

        <DraggableWindow client:load id="recorder" title="REJESTRATOR_FOLKU.WAV" initialX={600} initialY={200} initialWidth={350}>
          <BazarSoundRecorder client:load />
        </DraggableWindow>
      </div>
    </div>

    <canvas id="cursor-canvas"></canvas>

    <!-- CLASSIC SITE MODE -->
    <div id="site-wrapper" class="site-mode hidden">
      <header class="classic-header">
        <div style="background: #000080; color: #fff; padding: 5px 15px; font-weight: bold; border: 2px inset #fff; display: flex; align-items: center; gap: 10px;">
          <img src="assets/low_poly_polonez.webp" style="height: 16px;" />
          RAPTEM.EXE
        </div>
        <div style="flex-grow: 1;">
          <Marquee text="RAPTEM - TEATR PRĘDKOŚCI I PRZEMIANY - NAJLEPSZY FOLK KUJAWSKI W INTERNECIE - ZAPRASZAMY NA WIDOWISKO - 100% TRADYCJI - 0% KOMPROMISU" />
        </div>
        <div class="win95-inset" style="padding: 5px; font-size: 10px; display: flex; gap: 10px;">
          <span>VISITORS:</span>
          <HitCounter client:load initialCount={12847} />
        </div>
      </header>

      <div class="classic-layout">
        <aside class="sidebar">
          <nav>
            <a href="#welcome" class="nav-link">📁 START</a>
            <a href="#muzyka" class="nav-link">📁 MUZYKA</a>
            <a href="#video" class="nav-link">📁 WIDEO</a>
            <a href="#galeria" class="nav-link">📁 GALERIA</a>
            <a href="#guestbook-anchor" class="nav-link">📁 KSIĘGA GOŚCI</a>
            <a href="#system" class="nav-link">💾 SYSTEM</a>
            <a href="#kontakt" class="nav-link">📞 KONTAKT</a>
            
            <button id="enter-os" class="nav-link os-trigger" style="margin-top: 20px; background: #000080; color: #fff;">
              🖥️ WEJDŹ NA PULPIT
            </button>
            <button id="enter-legacy" class="nav-link" style="margin-top: 10px; background: #800080; color: #fff; font-size: 10px;">
              🏺 WERSJA ORYGINALNA
            </button>
          </nav>
          
          <div class="win95-inset" style="margin-top: 30px; padding: 15px; background: #000; color: #0f0; font-family: monospace; font-size: 11px;">
            <div style="border-bottom: 1px solid #0f0; margin-bottom: 10px; padding-bottom: 5px; font-weight: bold;">
              🔮 WYROCZNIA KUJAWSKA
            </div>
            <p id="oracle-text" style="min-height: 40px;"></p>
            <button id="refresh-oracle" style="margin-top: 10px; background: #0f0; color: #000; border: none; width: 100%; cursor: pointer; font-family: monospace; font-weight: bold;">
              LOSUJ LORE
            </button>
          </div>

          <div style="margin-top: 30px; text-align: center;">
            <img src="assets/construction.gif" style="width: 80px;" />
            <p style="font-size: 9px; color: #000; margin-top: 10px; font-weight: bold;">ZOPTYMALIZOWANO DLA IE 5.0</p>
            <img src="assets/new.gif" style="width: 40px; margin-top: 10px;" />
          </div>
        </aside>

        <main class="main-content">
          <section id="welcome" style="margin-bottom: 80px;">
            <div class="section-folder-tab">📁 C:\STRONA\WITAMY</div>
            <h2 class="wordart-rainbow" style="font-size: 4rem; margin-bottom: 30px;">RAPTEM: KUJAWY 2026</h2>
            <div style="border: 3px outset #fff; padding: 30px; background: rgba(255,255,255,0.08); backdrop-filter: blur(8px); position: relative; border-radius: 2px;">
              <img src="assets/dancer_pixel.webp" style="position: absolute; top: -30px; right: -30px; width: 80px; z-index: 10;" />
              <p style="font-size: 1.4rem; line-height: 1.6; color: #fff; text-shadow: 2px 2px #000; font-weight: 500;">
                Jesteśmy grupą <strong>Raptem</strong>. Nasze korzenie sięgają głęboko w kujawską ziemię, między wsie <strong>Murzynno</strong> i <strong>Murzynek</strong>. To właśnie tam narodziła się wizja eksperymentalnego teatru ludowego i regionalnych inscenizacji.
              </p>
              
              <div style="display: flex; gap: 30px; margin: 40px 0; flex-wrap: wrap; justify-content: center;">
                 <div style="position: relative;">
                    <img src="assets/TeatrGospoda_jan26.webp" style="width: 100%; border: 12px double #c0c0c0; box-shadow: 20px 20px 0 #000;" />
                    <span style="position: absolute; bottom: 20px; right: 20px; background: #ffff00; color: #000; padding: 5px 15px; font-weight: bold; border: 2px solid #000;">PREMIERA 2026</span>
                 </div>
              </div>
              
              <div style="display: flex; justify-content: space-around; margin: 60px 0;">
                <div class="interactive-asset" onclick="window.dispatchEvent(new CustomEvent('open-window', { detail: 'polonez' }))">
                  <VaporwaveTroope client:load assetUrl="assets/low_poly_polonez.webp" alt="Polonez" size={250} glowColor="cyan" />
                  <p style="text-align: center; font-weight: bold; color: #0ff;">MÓJ POLONEZ [KLIKNIJ]</p>
                </div>
                <div class="interactive-asset" onclick="window.dispatchEvent(new CustomEvent('open-window', { detail: 'gallery_os' }))">
                  <VaporwaveTroope client:load assetUrl="assets/1000001788.webp" alt="Ekipa" size={250} glowColor="magenta" />
                  <p style="text-align: center; font-weight: bold; color: #f0f;">EKIPA [KLIKNIJ]</p>
                </div>
              </div>
            </div>
          </section>

          <section id="muzyka" style="margin-bottom: 80px;">
            <div class="section-folder-tab">📁 C:\STRONA\AKORDEON</div>
            <h2 class="wordart-3dblue" style="font-size: 3.5rem; margin-bottom: 30px;">BAZAR-MASTER 9000</h2>
            <div class="win95-inset" style="padding: 25px; background: #c0c0c0; border: 4px outset #fff;">
              <p style="color: #000; font-weight: bold; margin-bottom: 20px; font-size: 1.1rem; background: #ffff00; display: inline-block; padding: 2px 10px;">INSTRUMENT INTERAKTYWNY:</p>
              <div style="height: 450px; overflow: hidden; border: 4px inset #fff; background: #000;">
                <AccordionGame client:load />
              </div>
              <div style="margin-top: 30px;">
                <div style="display: flex; gap: 10px; margin-bottom: 10px;">
                   <button onclick="window.dispatchEvent(new CustomEvent('open-window', { detail: 'recorder' }))" class="win95-button">NAGRAJ SWÓJ FOLK</button>
                   <button onclick="window.dispatchEvent(new CustomEvent('open-window', { detail: 'defrag' }))" class="win95-button">DEFRAG_BAZAR.EXE</button>
                </div>
                <StagePlayer client:load audioUrl="assets/handpan_grill.mp4" />
              </div>
            </div>
          </section>

          <section id="video" style="margin-bottom: 80px;">
            <div class="section-folder-tab">📁 C:\STRONA\WIDEO</div>
            <h2 class="wordart-outline" style="font-size: 3.5rem; margin-bottom: 30px;">VHS / ARCHIWUM</h2>
            <div style="border: 6px double #fff; background: #000; padding: 15px; box-shadow: 10px 10px 30px rgba(0,0,0,0.5);">
              <RetroVideo title="RAPTEM LIVE: RYTUAŁ BAZAROWY" src="assets/handpan_grill.mp4" />
            </div>
          </section>

          <section id="galeria" style="margin-bottom: 80px;">
            <div class="section-folder-tab">📁 C:\STRONA\GALERIA</div>
            <h2 class="wordart-rainbow" style="font-size: 3.5rem; margin-bottom: 30px;">FOTO GALERIA</h2>
            <div class="win95-inset" style="padding: 15px; background: #808080;">
              <Gallery client:load />
            </div>
          </section>

          <section id="guestbook-anchor" style="margin-bottom: 80px;">
            <div class="section-folder-tab">📁 C:\STRONA\KSIĘGA_GOŚCI</div>
            <h2 class="wordart-outline" style="font-size: 3.5rem; margin-bottom: 30px;">KSIĘGA GOŚCI</h2>
            <div class="win95-inset" style="padding: 20px; background: #c0c0c0;">
              <Guestbook client:load />
            </div>
          </section>

          <section id="system" style="margin-bottom: 80px;">
            <div class="section-folder-tab">📁 C:\STRONA\SYSTEM</div>
            <h2 class="wordart-outline" style="font-size: 3.5rem; margin-bottom: 30px; color: #0f0; text-shadow: 2px 2px #000;">BAZAR TERMINAL</h2>
            <div style="height: 500px; border: 6px inset #fff; background: #000; box-shadow: inset 0 0 50px #030;">
              <BazarTerminal client:load />
            </div>
            <div style="margin-top: 20px; display: flex; gap: 10px;">
              <button onclick="window.dispatchEvent(new CustomEvent('open-window', { detail: 'logs' }))" class="win95-button">Pokaż Logi</button>
              <button onclick="window.dispatchEvent(new CustomEvent('open-window', { detail: 'terminal' }))" class="win95-button">Otwórz w Oknie</button>
              <button onclick="window.dispatchEvent(new CustomEvent('open-window', { detail: 'scanner' }))" class="win95-button">Skaner Folkloru</button>
            </div>
          </section>

          <section id="kontakt" style="padding-bottom: 120px;">
            <div class="section-folder-tab">📁 C:\STRONA\KONTAKT</div>
            <h2 class="wordart-3dblue" style="font-size: 3.5rem; margin-bottom: 30px;">KONTAKT</h2>
            <div class="win95-inset" style="padding: 40px; display: flex; gap: 40px; align-items: center; background: #c0c0c0; color: #000; border: 4px outset #fff;">
              <div style="flex-grow: 1;">
                <p style="font-size: 2rem; font-weight: bold; margin-bottom: 10px;">Manager: Mirek</p>
                <p style="font-family: monospace; font-size: 1.2rem;">📱 TEL: 500-TEATR-00</p>
                <p style="font-family: monospace; font-size: 1.2rem;">📧 MAIL: raptem@bazar.pl</p>
                <div style="margin-top: 30px; border-top: 2px solid #000; padding-top: 20px; display: flex; align-items: center; gap: 15px;">
                   <img src="assets/pks_stop.webp" style="height: 30px;" />
                   <HitCounter client:load initialCount={12847} />
                </div>
              </div>
              <img src="assets/1000003330.webp" style="width: 250px; border: 8px solid #000; filter: contrast(1.3) grayscale(0.2) drop-shadow(10px 10px 0 #888);" />
            </div>
          </section>
        </main>
      </div>
    </div>

    <!-- OS MODE OVERLAY -->
    <div id="os-wrapper" class="os-mode hidden">
      <button id="exit-os" class="win95-button" style="position: fixed; top: 10px; right: 10px; z-index: 50000; padding: 5px 20px; font-weight: bold; background: #c0c0c0;">
        [X] POWRÓT DO STRONY
      </button>
      
      <DesktopSurface client:load />
      
      <div class="app-container">
        <DesktopWidgets client:load />
        <main class="main-frame">
            <div class="desktop-icon" id="icon-computer"><img src="assets/polonez.webp" /><span>Mój Polonez</span></div>
            <div class="desktop-icon" id="icon-trash"><img src="assets/spirytus.webp" style="filter: grayscale(1);" /><span>Kosz</span></div>
            <div class="desktop-icon" id="icon-network"><img src="assets/pks_stop.webp" /><span>Otoczenie</span></div>
            <div class="desktop-icon" id="icon-terminal"><img src="assets/polonez.webp" style="filter: contrast(2) grayscale(1);" /><span>Terminal</span></div>
            <div class="desktop-icon" id="icon-lore"><img src="assets/construction.gif" style="filter: hue-rotate(270deg);" /><span>MANIFEST</span></div>
            <div class="desktop-icon" id="icon-gallery"><img src="assets/kujawiak_retro_folk.webp" /><span>Galeria</span></div>
            <div class="desktop-icon" id="icon-quests"><img src="assets/construction.gif" /><span>MISJE</span></div>
            <div class="desktop-icon" id="icon-accordion"><img src="assets/accordion.webp" /><span>Bazar-Master</span></div>
            <div class="desktop-icon" id="icon-logs"><img src="assets/spirytus.webp" style="filter: hue-rotate(90deg);" /><span>Logi Systemu</span></div>
            <div class="desktop-icon" id="icon-winamp"><img src="assets/pks_stop.webp" style="filter: hue-rotate(180deg);" /><span>WinAmp</span></div>
            <div class="desktop-icon" id="icon-rituals"><img src="assets/spirytus.webp" style="filter: hue-rotate(45deg) saturate(2);" /><span>RYTUAŁY</span></div>
            <div class="desktop-icon" id="icon-archive"><img src="assets/construction.gif" style="filter: hue-rotate(180deg);" /><span>ARCHIWUM</span></div>
            <div class="desktop-icon" id="icon-map"><img src="assets/polonez.webp" style="filter: hue-rotate(200deg);" /><span>MAPA</span></div>
            <div class="desktop-icon" id="icon-scanner"><img src="assets/spirytus.webp" style="filter: contrast(3) invert(1);" /><span>SKANER</span></div>
            <div class="desktop-icon" id="icon-profile"><img src="assets/dancer_pixel.webp" style="filter: drop-shadow(2px 2px 0 #000);" /><span>PROFIL SOŁTYSA</span></div>
            <div class="desktop-icon" id="icon-guestbook"><img src="assets/1000003330.webp" style="filter: hue-rotate(120deg);" /><span>Księga Gości</span></div>
            <div class="desktop-icon" id="icon-defrag"><img src="assets/construction.gif" style="filter: grayscale(1);" /><span>Defragmentacja</span></div>
            <div class="desktop-icon" id="icon-recorder"><img src="assets/spirytus.webp" style="filter: hue-rotate(200deg);" /><span>Rejestrator</span></div>
            <div class="desktop-icon" id="enter-legacy-icon"><img src="assets/1000001788.webp" style="filter: sepia(1) hue-rotate(-50deg);" /><span>Starzy Raptem</span></div>
          </div>
        </main>
      </div>
    </div>

    <!-- LEGACY MODE OVERLAY -->
    <div id="legacy-wrapper" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 500000; background: #000;">
      <button id="exit-legacy" class="win95-button" style="position: fixed; top: 10px; right: 10px; z-index: 600000; padding: 5px 20px; font-weight: bold; background: #c0c0c0;">
        [X] POWRÓT DO NOWEJ WERSJI
      </button>
      <iframe src="/raptem/legacy_v1" style="width: 100%; height: 100%; border: none;"></iframe>
    </div>

    <!-- PERSISTENT SYSTEM UI -->
    <div class="persistent-component hidden">
      <Taskbar client:load />
    </div>
    <div class="persistent-component hidden">
      <MirekHelper client:load />
    </div>
    <div class="persistent-component">
      <BootSequence />
    </div>

    <!-- OVERLAYS -->
    <div id="bsod-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #0000aa; color: #fff; z-index: 1000000; padding: 50px; font-family: 'Courier New', monospace;">
      <p style="background: #fff; color: #0000aa; display: inline-block; padding: 0 10px;">Windows</p>
      <p style="margin-top: 20px;">A fatal exception 0E has occurred at 0028:C0011E36. The current application will be terminated.</p>
      <p style="margin-top: 20px;">* Press any key to continue _</p>
    </div>

    <div id="shutdown-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #000; color: #f80; z-index: 2000000; padding: 50px; font-family: 'Courier New', monospace; text-align: center;">
      <h2 style="color: #f80; font-size: 2.5rem; margin-top: 20vh;">MOŻNA TERAZ BEZPIECZNIE WYŁĄCZYĆ SOŁTYSA.</h2>
      <img src="assets/spirytus.webp" style="margin-top: 50px; width: 120px; opacity: 0.7;" />
    </div>

    <script src="../scripts/CursorTrail.js"></script>
    <script>
      import soundManager from '../scripts/SoundManager.js';
      
      const enterOS = document.getElementById('enter-os');
      const exitOS = document.getElementById('exit-os');
      const enterLegacy = document.getElementById('enter-legacy');
      const exitLegacy = document.getElementById('exit-legacy');
      
      const siteWrapper = document.getElementById('site-wrapper');
      const osWrapper = document.getElementById('os-wrapper');
      const legacyWrapper = document.getElementById('legacy-wrapper');

      const globalUI = document.getElementById('global-ui');
      const windowLayer = document.getElementById('window-layer');

      function hideAll() {
        siteWrapper?.classList.add('hidden');
        osWrapper?.classList.add('hidden');
        legacyWrapper?.classList.add('hidden');
        
        // Default: show new UI
        globalUI?.classList.remove('hidden');
        windowLayer?.classList.remove('hidden');
        document.querySelectorAll('.persistent-component').forEach(el => el.classList.remove('hidden'));
      }

      window.switchMode = (mode) => {
        hideAll();
        if (mode === 'site') {
          siteWrapper?.classList.remove('hidden');
          // Hide NEW UI in site mode
          globalUI?.classList.add('hidden');
          windowLayer?.classList.add('hidden');
          document.querySelectorAll('.persistent-component').forEach(el => el.classList.add('hidden'));
        }
        if (mode === 'os') {
          osWrapper?.classList.remove('hidden');
          // Unhide UI
          globalUI?.classList.remove('hidden');
          windowLayer?.classList.remove('hidden');
          document.querySelectorAll('.persistent-component').forEach(el => el.classList.remove('hidden'));
        }
        if (mode === 'legacy') {
          legacyWrapper?.classList.remove('hidden');
          // Hide NEW UI in legacy mode
          globalUI?.classList.add('hidden');
          windowLayer?.classList.add('hidden');
          document.querySelectorAll('.persistent-component').forEach(el => el.classList.add('hidden'));
        }
      };

      enterOS?.addEventListener('click', () => {
        soundManager.play('startup');
        window.switchMode('os');
      });

      exitOS?.addEventListener('click', () => {
        soundManager.play('click');
        window.switchMode('site');
      });

      enterLegacy?.addEventListener('click', () => {
        soundManager.play('startup');
        window.switchMode('legacy');
      });

      exitLegacy?.addEventListener('click', () => {
        soundManager.play('click');
        window.switchMode('site'); // Go back to Site Mode
      });

      document.getElementById('enter-legacy-icon')?.addEventListener('dblclick', () => {
        soundManager.play('startup');
        window.switchMode('legacy');
      });

      // Oracle Logic
      import { getFolkFortune } from '../scripts/KujawianOracle.js';
      const oracleText = document.getElementById('oracle-text');
      const refreshOracle = document.getElementById('refresh-oracle');

      const updateOracle = () => {
        if (oracleText) {
          oracleText.innerText = getFolkFortune();
        }
      };

      refreshOracle?.addEventListener('click', () => {
        soundManager.play('click');
        updateOracle();
      });

      updateOracle();

      // Initial State Sound
      window.addEventListener('load', () => {
        soundManager.play('startup');
      });

      // Window Management Helpers
      function openWindow(id) {
        window.dispatchEvent(new CustomEvent('open-window', { detail: id }));
      }

      // Hook up icons in OS Mode
      document.getElementById('icon-terminal')?.addEventListener('dblclick', () => openWindow('terminal'));
      document.getElementById('icon-lore')?.addEventListener('dblclick', () => openWindow('lore'));
      document.getElementById('icon-rituals')?.addEventListener('dblclick', () => openWindow('rituals'));
      document.getElementById('icon-archive')?.addEventListener('dblclick', () => openWindow('archive'));
      document.getElementById('icon-map')?.addEventListener('dblclick', () => openWindow('map'));
      document.getElementById('icon-scanner')?.addEventListener('dblclick', () => openWindow('scanner'));
      document.getElementById('icon-profile')?.addEventListener('dblclick', () => openWindow('profile'));
      document.getElementById('icon-gallery')?.addEventListener('dblclick', () => openWindow('gallery_os'));
      document.getElementById('icon-quests')?.addEventListener('dblclick', () => openWindow('quest_log'));
      document.getElementById('icon-computer')?.addEventListener('dblclick', () => openWindow('polonez'));
      document.getElementById('icon-network')?.addEventListener('dblclick', () => openWindow('network'));
      document.getElementById('icon-accordion')?.addEventListener('dblclick', () => openWindow('accordion'));
      document.getElementById('icon-logs')?.addEventListener('dblclick', () => openWindow('logs'));
      document.getElementById('icon-winamp')?.addEventListener('dblclick', () => openWindow('winamp'));
      document.getElementById('icon-guestbook')?.addEventListener('dblclick', () => openWindow('guestbook'));
      document.getElementById('icon-defrag')?.addEventListener('dblclick', () => openWindow('defrag'));
      document.getElementById('icon-recorder')?.addEventListener('dblclick', () => openWindow('recorder'));
      
      // Global click sound
      document.addEventListener('click', () => {
        soundManager.play('click');
      });

      // BSOD Trigger
      document.getElementById('icon-trash')?.addEventListener('dblclick', () => {
         document.getElementById('bsod-overlay').style.display = 'block';
         soundManager.play('error');
      });

      document.getElementById('bsod-overlay')?.addEventListener('click', () => {
         document.getElementById('bsod-overlay').style.display = 'none';
      });

      // Exposure to global scope
      window.openWindow = openWindow;
    </script>
    
    <style>
      .background-texture {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('assets/kujawy_pattern.webp');
        background-size: 400px;
        opacity: 0.08;
        pointer-events: none;
        z-index: -1;
      }
      .section-folder-tab {
        background: #c0c0c0;
        border: 2px outset #fff;
        border-bottom: none;
        padding: 8px 25px;
        font-family: var(--font-win95);
        font-size: 16px;
        font-weight: bold;
        display: inline-block;
        color: #000;
        margin-bottom: -2px;
        position: relative;
        z-index: 5;
      }
      .interactive-asset {
        cursor: pointer;
        transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      }
      .interactive-asset:hover {
        transform: scale(1.1) translateY(-10px);
      }
    </style>
  </body>
</html>
